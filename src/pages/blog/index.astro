---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<BaseLayout title="Blog | Astro Decap Blog" description="All blog posts from the Decap CMS.">
  <section class="mx-auto max-w-3xl px-6 py-16">
    <h1 class="text-4xl font-bold tracking-tight text-slate-900">Blog</h1>
    <p class="mt-4 text-lg text-slate-600">
      Posts are managed from the private admin panel and stored as Markdown in the repository.
    </p>

    {
      posts.length === 0 ? (
        <p class="mt-12 rounded-xl border border-dashed border-slate-300 bg-white p-8 text-center text-slate-500">
          No posts yet. Add your first post from <code class="text-sm">/admin</code> after deployment.
        </p>
      ) : (
        <ul class="mt-12 divide-y divide-slate-200">
          {posts.map((post) => (
            <li class="py-8 first:pt-0">
              <article>
                <time
                  datetime={post.data.pubDate.toISOString()}
                  class="text-sm font-medium text-slate-500"
                >
                  {post.data.pubDate.toLocaleDateString("en-US", {
                    year: "numeric",
                    month: "long",
                    day: "numeric",
                  })}
                </time>
                <h2 class="mt-2 text-2xl font-semibold text-slate-900">
                  <a href={`/blog/${post.id}`} class="hover:text-brand-600 transition-colors">
                    {post.data.title}
                  </a>
                </h2>
                <p class="mt-2 text-slate-600">{post.data.description}</p>
                <p class="mt-3 text-sm text-slate-500">By {post.data.author}</p>
              </article>
            </li>
          ))}
        </ul>
      )
    }
  </section>
</BaseLayout>
