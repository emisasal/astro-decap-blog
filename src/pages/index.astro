---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<BaseLayout title="Home | Astro Decap Blog">
  <section class="mx-auto max-w-5xl px-6 py-16">
    <div class="max-w-2xl">
      <p class="text-sm font-medium uppercase tracking-wide text-brand-600">Learning project</p>
      <h1 class="mt-3 text-4xl font-bold tracking-tight text-slate-900 sm:text-5xl">
        Deploy a blog to Netlify and publish from production
      </h1>
      <p class="mt-6 text-lg leading-relaxed text-slate-600">
        This site uses Astro for the frontend, Tailwind CSS for styling, and Decap CMS for
        content management. After deployment, log in at <code class="rounded bg-slate-100 px-1.5 py-0.5 text-sm">/admin</code> to add blog posts that commit directly to your Git repository.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a
          href="/blog"
          class="inline-flex items-center rounded-lg bg-brand-600 px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-brand-700 transition-colors"
        >
          Read the blog
        </a>
        <a
          href="/about"
          class="inline-flex items-center rounded-lg border border-slate-300 bg-white px-5 py-2.5 text-sm font-semibold text-slate-700 hover:bg-slate-50 transition-colors"
        >
          Learn about this stack
        </a>
      </div>
    </div>

    {
      posts.length > 0 && (
        <div class="mt-20">
          <h2 class="text-2xl font-bold text-slate-900">Latest posts</h2>
          <ul class="mt-6 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {posts.map((post) => (
              <li class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm hover:shadow-md transition-shadow">
                <time
                  datetime={post.data.pubDate.toISOString()}
                  class="text-xs font-medium text-slate-500"
                >
                  {post.data.pubDate.toLocaleDateString("en-US", {
                    year: "numeric",
                    month: "long",
                    day: "numeric",
                  })}
                </time>
                <h3 class="mt-2 text-lg font-semibold text-slate-900">
                  <a href={`/blog/${post.id}`} class="hover:text-brand-600 transition-colors">
                    {post.data.title}
                  </a>
                </h3>
                <p class="mt-2 text-sm leading-relaxed text-slate-600">{post.data.description}</p>
              </li>
            ))}
          </ul>
        </div>
      )
    }
  </section>
</BaseLayout>
